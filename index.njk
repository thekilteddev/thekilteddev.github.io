---
layout: base.njk
---
<div class="wrap">
  <div class="article-head">
    <p class="kicker">{{ site.tagline }}</p>
    <h1><span class="hy">the</span>kilteddev</h1>
    <p class="standfirst">A Scotsman who dabbles in development. What eighteen concurrent AI coding projects actually teach you, written down honestly.</p>
  </div>

  <section aria-label="Posts">
    {% for post in collections.posts %}
    <article style="border-top: 1px solid var(--rule); padding: 28px 0;">
      <p class="kicker" style="margin-bottom: 10px;">{{ post.data.kicker }}</p>
      <h2 style="margin-bottom: 10px;"><a href="{{ post.url }}" style="color: var(--ink); text-decoration: none;">{{ post.data.title }}</a></h2>
      <p style="color: var(--ink-dim); margin-bottom: 12px;">{{ post.data.standfirst }}</p>
      <p style="font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-dim); margin: 0;">{{ post.date | postDate if postDate else post.date.toISOString().slice(0,10) }}</p>
    </article>
    {% endfor %}
  </section>
</div>
